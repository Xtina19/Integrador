# =============================================================================
# LibroSys Backend — variables de entorno
# =============================================================================

# --- Legacy Express (server.js / mssql) ---
DB_SERVER=
DB_USER=
DB_PASSWORD=
DB_DATABASE=
PORT=3001

# --- MySQL (rutas delgadas: /api/monedas, etc.) ---
# No use DB_USER/DB_PASSWORD del legacy mssql aquí.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=librosys
MYSQL_USER=root
MYSQL_PASSWORD=

# --- Módulo Inventario (Fase 4) ---
NODE_ENV=development
INVENTARIO_PORT=3002
LOG_LEVEL=info
DB_DRIVER=memory
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=librosys
# DB_USER=
# DB_PASSWORD=
OUTBOX_POLL_MS=5000
CORS_ORIGIN=*
