# URL base del backend Express (sin barra final)
VITE_API_URL=http://localhost:3001

# Activar API real por módulo (false = Mock Data)
VITE_USE_API_INVENTARIO=false
# Ventas: requiere backend con /api/v1/ventas (sin mocks de facturación)
VITE_USE_API_VENTAS=true
VITE_USE_API_COMPRAS=false
VITE_USE_API_IMPORTACIONES=false
VITE_USE_API_EVENTOS=false
VITE_USE_API_EDITORIALES=false
VITE_USE_API_USUARIOS=false
VITE_USE_API_TRANSFERENCIAS=false
VITE_USE_API_REPORTES=false
VITE_USE_API_CONFIGURACION=false
VITE_USE_API_AUDITORIA=false

# Timeout HTTP en milisegundos
VITE_API_TIMEOUT=15000
